MESHY_API_KEY=msy_dummy_api_key_for_test_mode_12345678
NEXT_PUBLIC_SITE_URL=https://augmenta3d.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudflare R2
R2_ACCOUNT_ID=
# Optional override if you do not want to derive the endpoint from R2_ACCOUNT_ID.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=https://cdn.example.com
# Private bucket holding GLB/USDZ model files, served ONLY via short-lived
# presigned URLs minted by /api/model-access/<token> (Plan 2 kill switch). It
# must have NO public domain bound, and a CORS policy allowing GET from your
# site + merchants' allowed_embed_domains so the in-browser viewer can fetch the
# redirected presigned URL. Falls back to R2_BUCKET_NAME when unset.
R2_PRIVATE_BUCKET_NAME=
# Secret used to sign short-lived model access tokens (/api/model-access/<token>).
# Defaults to the Supabase service role key if unset; a dedicated random value
# is recommended.
MODEL_ACCESS_SECRET=your_long_random_model_access_secret

# ── Cron / maintenance ───────────────────────────────────────────────────────
# Shared secret guarding maintenance routes (e.g. POST /api/generation/cleanup,
# which fails generations stuck in queued/running). Send as "Authorization:
# Bearer <CRON_SECRET>". Vercel Cron sends this automatically when set here.
CRON_SECRET=your_long_random_cron_secret

# ── Email (Resend) ───────────────────────────────────────────────────────
# Transactional + marketing email via Resend (https://resend.com).
# Leave RESEND_API_KEY blank to disable all email sending.
RESEND_API_KEY=re_your_resend_api_key
# From address for all outgoing email. Domain must be verified in Resend.
EMAIL_FROM=Augmenta <noreply@augmenta3d.com>
# Admin recipient for internal review/failure notifications.
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com
# Resend Audience id that signups are synced into for marketing broadcasts.
RESEND_AUDIENCE_ID=
# Secret used to sign one-click unsubscribe links. Defaults to the Supabase
# service role key if unset, but a dedicated random value is recommended.
UNSUBSCRIBE_SECRET=your_long_random_unsubscribe_secret
# Secret used to sign short-lived AR preview links (/ar-preview/<token>).
# Defaults to the Supabase service role key if unset, but a dedicated random
# value is recommended.
AR_PREVIEW_SECRET=your_long_random_ar_preview_secret

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
# All optional — the app builds and runs without these; billing endpoints return
# 503 until configured. Create the products/prices in the Stripe dashboard, then
# paste the Price IDs below. Prices are EUR (Proposal A price book).
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Recurring monthly plan prices (€29 / €69 / €149):
STRIPE_PRICE_STARTER=price_xxx_starter_monthly
STRIPE_PRICE_GROWTH=price_xxx_growth_monthly
STRIPE_PRICE_STUDIO=price_xxx_studio_monthly
# One-time onboarding/setup fee (€99, waived on annual):
STRIPE_PRICE_SETUP_FEE=price_xxx_setup_fee
# One-time generation top-up packs (€19 / €39 / €69):
STRIPE_PRICE_TOPUP_10=price_xxx_topup_10
STRIPE_PRICE_TOPUP_25=price_xxx_topup_25
STRIPE_PRICE_TOPUP_50=price_xxx_topup_50
# Metered view overage (Growth/Studio): create a Billing Meter with event name
# "ar_view_overage" (or set STRIPE_METER_VIEW_OVERAGE_EVENT to match yours), then
# a metered recurring price on that meter. Unset = over-quota degrades to poster.
STRIPE_PRICE_VIEW_OVERAGE=price_xxx_view_overage
# STRIPE_METER_VIEW_OVERAGE_EVENT=ar_view_overage

# ── Admin user setup (NEVER commit passwords to git) ──────────────────────
# 1. Create a Supabase auth user in the Dashboard or via:
#      supabase auth admin create-user --email admin@yourdomain.com --password <strong_password>
# 2. Then set the admin flag + username in your DB:
#      UPDATE profiles
#        SET is_platform_admin = true, username = 'MegaAdmin'
#        WHERE id = '<uuid from step 1>';
# 3. Log in at /login with email "admin@yourdomain.com" OR username "MegaAdmin".
# The password is NEVER stored in .env or source code.
