MESHY_API_KEY=msy_dummy_api_key_for_test_mode_12345678
NEXT_PUBLIC_SITE_URL=https://veridianar.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudflare R2
R2_ACCOUNT_ID=
# Optional override if you do not want to derive the endpoint from R2_ACCOUNT_ID.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=https://cdn.example.com

# ── Cron / maintenance ───────────────────────────────────────────────────────
# Shared secret guarding maintenance routes (e.g. POST /api/generation/cleanup,
# which fails generations stuck in queued/running). Send as "Authorization:
# Bearer <CRON_SECRET>". Vercel Cron sends this automatically when set here.
CRON_SECRET=your_long_random_cron_secret

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
# All optional — the app builds and runs without these; billing endpoints return
# 503 until configured. Create the products/prices in the Stripe dashboard, then
# paste the Price IDs below. Prices are EUR (Proposal A price book).
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Recurring monthly plan prices (€29 / €69 / €149):
STRIPE_PRICE_STARTER=price_xxx_starter_monthly
STRIPE_PRICE_GROWTH=price_xxx_growth_monthly
STRIPE_PRICE_STUDIO=price_xxx_studio_monthly
# One-time onboarding/setup fee (€99, waived on annual):
STRIPE_PRICE_SETUP_FEE=price_xxx_setup_fee
# One-time generation top-up packs (€19 / €39 / €69):
STRIPE_PRICE_TOPUP_10=price_xxx_topup_10
STRIPE_PRICE_TOPUP_25=price_xxx_topup_25
STRIPE_PRICE_TOPUP_50=price_xxx_topup_50

# ── Admin ──────────────────────────────────────────────────────────────────
# Email sent to admin when a product reaches awaiting_review or generation_failed.
# Uses Resend (https://resend.com). Leave blank to disable email notifications.
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com
RESEND_API_KEY=re_your_resend_api_key

# ── Admin user setup (NEVER commit passwords to git) ──────────────────────
# 1. Create a Supabase auth user in the Dashboard or via:
#      supabase auth admin create-user --email admin@yourdomain.com --password <strong_password>
# 2. Then set the admin flag + username in your DB:
#      UPDATE profiles
#        SET is_platform_admin = true, username = 'MegaAdmin'
#        WHERE id = '<uuid from step 1>';
# 3. Log in at /login with email "admin@yourdomain.com" OR username "MegaAdmin".
# The password is NEVER stored in .env or source code.
